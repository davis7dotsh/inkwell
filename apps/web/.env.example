# Copy to .env.local and fill in (see PLAN.md §9 for where each value comes from).

# Clerk publishable key (Clerk dashboard → API keys).
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx

# Convex deployment URL (npx convex dev in packages/backend prints it).
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# inkwell-api worker origin (after `wrangler deploy` in apps/api).
VITE_API_URL=https://inkwell-api.your-account.workers.dev
