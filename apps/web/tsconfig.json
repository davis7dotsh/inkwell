{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "skipLibCheck": true
  },
  // Keep the backend runtime's process.env ambient available while importing
  // generated Convex API types from source.
  "include": ["src", "../../packages/backend/convex/env.d.ts"]
}
