{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "skipLibCheck": true
  },
  // The backend env.d.ts ambient (process.env in the Convex runtime) must be
  // in this program too: importing the generated Convex api type-checks
  // ../../packages/backend/convex/http.ts from source.
  "include": ["src", "../../packages/backend/convex/env.d.ts"]
}
