# Copy to .env.local and fill in. All EXPO_PUBLIC_ vars are inlined into the
# JS bundle at build time — never put secrets here.

# Clerk publishable key (Clerk dashboard → API keys).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Convex deployment URL (https://<deployment>.convex.cloud).
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# The inkwell-api Hono worker origin (no trailing slash).
EXPO_PUBLIC_API_URL=https://inkwell-api.example.workers.dev
