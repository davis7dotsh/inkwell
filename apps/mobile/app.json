{
  "expo": {
    "name": "Inkwell",
    "slug": "inkwell",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "inkwell",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "sh.davis7.inkwell",
      "appleTeamId": "4UQML39V9S",
      "infoPlist": {
        "CFBundleDisplayName": "$(INKWELL_DISPLAY_NAME)"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "sh.davis7.inkwell"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withDevVariant",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1B4F8A",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          },
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180
        }
      ],
      "expo-font",
      "expo-sqlite",
      "expo-web-browser",
      "expo-secure-store",
      [
        "@clerk/expo",
        {
          "appleSignIn": false,
          "keychainService": "sh.davis7.inkwell.production"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Inkwell uses the microphone to record voice memos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
