{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "inkwell-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-09",
  "env": {
    "dev": {
      "name": "inkwell-api-dev",
      "workers_dev": true,
      // Empty routes: without this, env.dev inherits the top-level custom
      // domain and a staging deploy steals api.inkwellapp.net from prod.
      "routes": [],
      "vars": {
        "CLERK_PUBLISHABLE_KEY": "pk_test_aGFwcHktc2hlZXAtODcuY2xlcmsuYWNjb3VudHMuZGV2JA",
        "CONVEX_URL": "https://abundant-grouse-159.convex.cloud"
      },
      // Bindings are non-inheritable: every env declares its own.
      "r2_buckets": [
        { "binding": "MEMOS", "bucket_name": "inkwell-memos-dev" }
      ]
    }
  },
  "workers_dev": true,
  "routes": [{ "pattern": "api.inkwellapp.net", "custom_domain": true }],
  "r2_buckets": [{ "binding": "MEMOS", "bucket_name": "inkwell-memos" }],
  "observability": {
    "enabled": true
  },
  // Filled at deploy time; secrets (FIRECRAWL_API_KEY, CLERK_SECRET_KEY,
  // CONVEX_DEPLOY_KEY) go through `wrangler secret put`.
  "vars": {
    "CLERK_PUBLISHABLE_KEY": "pk_live_Y2xlcmsuaW5rd2VsbGFwcC5uZXQk",
    "CONVEX_URL": "https://judicious-mastiff-652.convex.cloud"
  }
}
