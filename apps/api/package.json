    "effect": "4.0.0-beta.84",
    "hono": "^4.12.24",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260608.1",
    "@effect/vitest": "4.0.0-beta.84",
    "typescript": "5.9.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  }
