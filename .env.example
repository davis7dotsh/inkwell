# Inkwell development environment.
# Copy this file to .env.local at the repository root and fill in real dev
# values. `pnpm api` and `pnpm web` both load that root file directly.
#
# Mobile public values remain mode-specific in apps/mobile/.env.development
# and apps/mobile/.env.production.

# ──────────────────────────────────────────────────────────────────────
# Firecrawl  (firecrawl.dev → dashboard → API Keys)
# Used by: apps/api
# ──────────────────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=fc-...

# ──────────────────────────────────────────────────────────────────────
# Clerk  (dashboard.clerk.com → create app "Inkwell" → API Keys page)
# While you're there: enable Email verification code sign-in, and turn on
# the Convex integration (it activates the "convex" JWT template).
# ──────────────────────────────────────────────────────────────────────
# Publishable key used by apps/api. Web needs the VITE_ alias below; mobile
# has its own EXPO_PUBLIC_ value in apps/mobile/.env.development.
CLERK_PUBLISHABLE_KEY=pk_test_...
# Secret key used by apps/api.
CLERK_SECRET_KEY=sk_test_...
# Frontend API URL / issuer domain — shown on the API Keys page,
# looks like https://verb-noun-00.clerk.accounts.dev
# Used by: Convex deployment env (CLERK_JWT_ISSUER_DOMAIN)
CLERK_JWT_ISSUER_DOMAIN=https://...clerk.accounts.dev
# OPTIONAL: JWKS public key (API Keys → "JWT public key", PEM) — lets the
# api worker verify sessions without a network call. Fine to skip for now.
CLERK_JWT_KEY=

# ──────────────────────────────────────────────────────────────────────
# Convex (run `pnpm --filter @inkwell/backend dev` once and log in; it creates
# the project and writes packages/backend/.env.local).
# ──────────────────────────────────────────────────────────────────────
# Deployment URL — used by: apps/web (VITE_CONVEX_URL),
# apps/mobile (EXPO_PUBLIC_CONVEX_URL)
CONVEX_URL=https://....convex.cloud
# HTTP actions origin — same subdomain, .site suffix instead of .cloud.
# Used by: apps/api for the shared-secret service routes.
CONVEX_SITE_URL=https://....convex.site
# Production deployment key from Convex deployment settings.
# Used by the production deployment workflow, not by the API worker.
CONVEX_DEPLOY_KEY=

# ──────────────────────────────────────────────────────────────────────
# Inkwell-internal
# ──────────────────────────────────────────────────────────────────────
# Shared secret between the API worker and Convex HTTP actions.
# Generate once: openssl rand -hex 32
# Used by: apps/api and the Convex deployment env
# (`pnpm --filter @inkwell/backend exec convex env set
# WORKER_SHARED_SECRET <value>`).
WORKER_SHARED_SECRET=

# ──────────────────────────────────────────────────────────────────────
# Web development (Vite only exposes VITE_-prefixed values)
# ──────────────────────────────────────────────────────────────────────
# Keep these aliases aligned with the shared dev values above.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_CONVEX_URL=https://....convex.cloud
# `pnpm api` listens here by default.
VITE_API_URL=http://localhost:8787

# ──────────────────────────────────────────────────────────────────────
# Runtime map
# ──────────────────────────────────────────────────────────────────────
# apps/api: root .env.local plus the `dev` Wrangler environment
# apps/web: root .env.local through Vite's envDir
# apps/mobile: apps/mobile/.env.development or .env.production
# Convex deployment env (not a file — `convex env set ...`):
#   CLERK_JWT_ISSUER_DOMAIN, WORKER_SHARED_SECRET
