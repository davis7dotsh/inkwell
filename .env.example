# Inkwell v2 — every credential the system needs, in one place.
# Fill the real values into .env.local (gitignored). During the monorepo
# build-out these get distributed into per-app files; collecting them all
# up front means Phase 2 integration is just paste-and-go.
#
# Setup walkthrough: PLAN.md §9. Sources for each value are noted below.

# ──────────────────────────────────────────────────────────────────────
# Firecrawl  (firecrawl.dev → dashboard → API Keys)
# Used by: apps/api (wrangler secret)
# ──────────────────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=fc-...

# ──────────────────────────────────────────────────────────────────────
# Clerk  (dashboard.clerk.com → create app "Inkwell" → API Keys page)
# While you're there: enable Email verification code sign-in, and turn on
# the Convex integration (it activates the "convex" JWT template).
# ──────────────────────────────────────────────────────────────────────
# Publishable key — used by: apps/web, apps/mobile, apps/api (plain var)
CLERK_PUBLISHABLE_KEY=pk_test_...
# Secret key — used by: apps/api (wrangler secret)
CLERK_SECRET_KEY=sk_test_...
# Frontend API URL / issuer domain — shown on the API Keys page,
# looks like https://verb-noun-00.clerk.accounts.dev
# Used by: Convex deployment env (CLERK_JWT_ISSUER_DOMAIN)
CLERK_JWT_ISSUER_DOMAIN=https://...clerk.accounts.dev
# OPTIONAL: JWKS public key (API Keys → "JWT public key", PEM) — lets the
# api worker verify sessions without a network call. Fine to skip for now.
CLERK_JWT_KEY=

# ──────────────────────────────────────────────────────────────────────
# Convex  (run `npx convex dev` once — or `pnpm dlx convex dev` — and log
# in; it creates the project and prints the deployment URL. Also visible
# at dashboard.convex.dev.)
# ──────────────────────────────────────────────────────────────────────
# Deployment URL — used by: apps/web (VITE_CONVEX_URL),
# apps/mobile (EXPO_PUBLIC_CONVEX_URL)
CONVEX_URL=https://....convex.cloud
# HTTP actions origin — same subdomain, .site suffix instead of .cloud.
# Used by: apps/api for the shared-secret service routes.
CONVEX_SITE_URL=https://....convex.site
# Production deployment key from Convex deployment settings.
# Used by the production deployment workflow, not by the API worker.
CONVEX_DEPLOY_KEY=

# ──────────────────────────────────────────────────────────────────────
# Inkwell-internal
# ──────────────────────────────────────────────────────────────────────
# Shared secret between the API worker and Convex HTTP actions.
# Generate once: openssl rand -hex 32
# Used by: apps/api (wrangler secret) and the Convex deployment env
# (`npx convex env set WORKER_SHARED_SECRET <value>`).
WORKER_SHARED_SECRET=

# ──────────────────────────────────────────────────────────────────────
# Reference: where each value ends up after the monorepo split
# ──────────────────────────────────────────────────────────────────────
# apps/api      (.dev.vars locally; `wrangler secret put` in prod):
#   FIRECRAWL_API_KEY, CLERK_SECRET_KEY, WORKER_SHARED_SECRET,
#   CLERK_PUBLISHABLE_KEY (var), CONVEX_SITE_URL (var), CLERK_JWT_KEY (opt)
# apps/web      (.env.local):
#   VITE_CLERK_PUBLISHABLE_KEY, VITE_CONVEX_URL, VITE_API_URL
# apps/mobile   (.env.local):
#   EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY, EXPO_PUBLIC_CONVEX_URL,
#   EXPO_PUBLIC_API_URL
# Convex deployment env (not a file — `npx convex env set ...`):
#   CLERK_JWT_ISSUER_DOMAIN, WORKER_SHARED_SECRET
#
# VITE_API_URL / EXPO_PUBLIC_API_URL = the deployed inkwell-api worker URL
# (https://inkwell-api.<your-subdomain>.workers.dev) — exists after the
# first `wrangler deploy`, so leave those for Phase 2.
