{
  "name": "inkwell",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "pnpm -r --parallel --no-bail --stream run dev",
    "mobile": "pnpm --filter inkwell-mobile start",
    "web": "pnpm --filter inkwell-web dev",
    "api": "pnpm --filter @inkwell/api dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "check:effect": "effect-language-service diagnostics --project tsconfig.json --format text --strict --severity error,warning --log-level none",
    "check:convex-codegen": "pnpm --filter @inkwell/backend codegen:check",
    "lint:mobile": "pnpm --filter inkwell-mobile lint",
    "build:web": "pnpm --filter inkwell-web build",
    "build:api": "pnpm --filter @inkwell/api build",
    "export:mobile:ios": "pnpm --filter inkwell-mobile export:ios",
    "check:ci": "pnpm format:check && pnpm typecheck && pnpm check:effect && pnpm test && pnpm lint:mobile && pnpm build:web && pnpm build:api && pnpm export:mobile:ios",
    "check": "pnpm check:ci && pnpm check:convex-codegen",
    "ipad": "pnpm --filter inkwell-mobile ipad",
    "iphone": "pnpm --filter inkwell-mobile iphone"
  },
  "devDependencies": {
    "@effect/language-service": "0.86.2",
    "prettier": "^3.8.4",
    "typescript": "5.9.3"
  }
}
